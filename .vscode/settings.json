{
    "cSpell.language": "en,ru",
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.git": true,
        "**/.vs": true,
        "**/.gitmodules": true,
        "**/.vsconfig": true,
        "**/*.booproj": true,
        "**/*.pidb": true,
        "**/*.suo": true,
        "**/*.user": true,
        "**/*.userprefs": true,
        "**/*.unityproj": true,
        "**/*.dll": true,
        "**/*.exe": true,
        "**/*.pdf": true,
        "**/*.mid": true,
        "**/*.midi": true,
        "**/*.wav": true,
        "**/*.gif": true,
        "**/*.ico": true,
        "**/*.jpg": true,
        "**/*.jpeg": true,
        "**/*.png": true,
        "**/*.psd": true,
        "**/*.tga": true,
        "**/*.tif": true,
        "**/*.tiff": true,
        "**/*.3ds": true,
        "**/*.3DS": true,
        "**/*.fbx": true,
        "**/*.FBX": true,
        "**/*.lxo": true,
        "**/*.LXO": true,
        "**/*.ma": true,
        "**/*.MA": true,
        "**/*.obj": true,
        "**/*.OBJ": true,
        "**/*.asset": true,
        "**/*.cubemap": true,
        "**/*.flare": true,
        "**/*.mat": true,
        "**/*.meta": true,
        "**/*.prefab": true,
        "**/*.unity": true,
        "build/": true,
        "Build/": true,
        "Library/": true,
        "library/": true,
        "obj/": true,
        "Obj/": true,
        "Logs/": true,
        "logs/": true,
        "ProjectSettings/": true,
        "UserSettings/": true,
        "temp/": true,
        "Temp/": true
    },
    "cSpell.languageSettings": [
        {
            "languageId": "csharp",
            "includeRegExpList": [
                "CStyleComment",
                "string",
                "csharp-namespace-path",
                "csharp-identifier-names"
            ],
            "ignoreRegExpList": [
                "csharp-usings",
                "csharp-type-declarations",
                "csharp-inheritance",
                "csharp-attributes",
                "csharp-generics",
                "Urls",
                "Email"
            ]
        }
    ],
    "cSpell.patterns": [
        {
            "name": "csharp-namespace-path",
            "pattern": "/(?<=namespace\\s+)[\\w.]+/g"
        },
        {
            "name": "csharp-identifier-names",
            "pattern": "/\\b_?[a-z][a-zA-Z0-9]{2,}\\b/g"
        },
        {
            "name": "csharp-usings",
            "pattern": "/^\\s*using\\s+.+$/gm"
        },
        {
            "name": "csharp-type-declarations",
            "pattern": "/^\\s*(?:public|internal|private|protected)?\\s*(?:abstract|sealed|partial|static)?\\s*(?:class|interface|struct|enum|record)\\s+\\w+.*$/gm"
        },
        {
            "name": "csharp-inheritance",
            "pattern": "/(?<=:\\s*)[\\w.\\s,<>]+(?=\\s*[{])/g"
        },
        {
            "name": "csharp-attributes",
            "pattern": "/\\[[^\\]]+\\]/g"
        },
        {
            "name": "csharp-generics",
            "pattern": "/<[^>]+>/g"
        }
    ],
    "dotrush.roslyn.projectOrSolutionFiles": [
        "d:\\UnityProj\\RPGFramework\\RPGFramework.slnx",
        "d:\\UnityProj\\RPGFramework\\Assembly-CSharp-Editor.csproj",
        "d:\\UnityProj\\RPGFramework\\Assembly-CSharp.csproj"
    ],
    "dotnet.defaultSolution": "RPGFramework.sln"
}